# ============================================================================
# CONTENT STORM — environment
# Copy to .env and fill in. .env is gitignored.
# ============================================================================

# --- Database (Supabase Postgres + pgvector) -------------------------------
# Pooled connection (pgbouncer, port 6543) used by the running app.
DATABASE_URL="postgresql://postgres.PROJECT:PASSWORD@aws-region.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct connection (port 5432) used by `prisma migrate`.
DIRECT_URL="postgresql://postgres.PROJECT:PASSWORD@aws-region.pooler.supabase.com:5432/postgres"

# --- Auth (Clerk) -----------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
# From the Clerk Dashboard -> Webhooks -> your endpoint signing secret.
CLERK_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"

# --- Async (Redis + BullMQ) — next sprint ----------------------------------
REDIS_URL="redis://default:PASSWORD@HOST:PORT"

# --- Intelligence layer -----------------------------------------------------
ANTHROPIC_API_KEY="sk-ant-..."
OPENAI_API_KEY="sk-..."        # utility model + text-embedding-3-small

# --- Media + storage (later sprints) ---------------------------------------
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"
S3_BUCKET="content-storm-assets"

# --- LTI 1.3 ------------------------------------------------------------
# Private key secret for AGS OAuth2 client_credentials (platform-specific)
LTI_CLIENT_SECRET=""
# Public app URL — used to build launchUrl and webhook challengeEndpoint
NEXT_PUBLIC_APP_URL="https://app.contentstorm.ai"

# --- Stripe (billing) -------------------------------------------------------
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Tier prices — SOVEREIGN has none; it's a custom contract, not a Stripe Price.
STRIPE_PRICE_PRO="price_..."                 # $49/mo flat
STRIPE_PRICE_ARCHITECT="price_..."           # $79-149/mo, metered (attach to the storm_credit_overage Billing Meter)
STRIPE_PRICE_ENTERPRISE_SANDBOX="price_..."  # $40-75/seat/mo, per-seat quantity

# Add-on prices — a la carte, every paid tier (S4.3). Federated Edge is listed
# for completeness but /api/billing/addons routes it to Contact Sales, not Checkout.
STRIPE_PRICE_ADDON_ARBITRAGE="price_..."         # +$49/mo
STRIPE_PRICE_ADDON_ONCHAIN="price_..."           # +$29/mo
STRIPE_PRICE_ADDON_PREMIUM_COMPUTE="price_..."   # +$39/mo
STRIPE_PRICE_ADDON_CLIPPER="price_..."           # +$39/mo
STRIPE_PRICE_ADDON_FEDERATED_EDGE="price_..."    # custom quote - manual/white-glove

# --- Remotion Lambda (video render) -----------------------------------------
# Deploy with: cd remotion && npm run lambda:deploy
REMOTION_AWS_REGION="us-east-1"
REMOTION_LAMBDA_FUNCTION=""   # e.g. remotion-render-4-0-290-mem3000mb-disk10240mb-240sec
REMOTION_SERVE_URL=""         # e.g. https://remotionlambda-useast1-xyz.s3.amazonaws.com/sites/content-storm/index.html
ELEVENLABS_API_KEY=""

# --- On-Chain Credentials (V2-5) ---------------------------------------------
# Wallet that signs every mint. Fund it with a small amount of ETH (Base) and
# MATIC (Polygon) for gas — mints are cheap but not free.
ONCHAIN_SIGNER_PRIVATE_KEY=""

# RPC endpoints — public defaults work but are rate-limited; use a paid
# provider (Alchemy/Infura/QuickNode) for production mint volume.
BASE_RPC_URL="https://mainnet.base.org"
POLYGON_RPC_URL="https://polygon-rpc.com"

# One-time setup: run `npx tsx scripts/register-eas-schema.ts base` and
# `npx tsx scripts/register-eas-schema.ts polygon`, then paste the two
# printed schemaUIDs here. Minting fails with a clear error until both are set.
EAS_SCHEMA_UID_BASE=""
EAS_SCHEMA_UID_POLYGON=""

# Override only if the defaults in src/lib/onchain.ts (sourced from
# docs.attest.org/docs/quick--start/contracts) turn out to be stale.
EAS_CONTRACT_ADDRESS_BASE=""
EAS_CONTRACT_ADDRESS_POLYGON=""
EAS_SCHEMA_REGISTRY_ADDRESS_BASE=""
EAS_SCHEMA_REGISTRY_ADDRESS_POLYGON=""

# --- Curriculum Arbitrage Engine (V2-6) --------------------------------------
# All four source adapters are keyless except PatentsView. GitHub works
# without a token but is capped at 60 req/hr unauthenticated (5000/hr with one).
GITHUB_TOKEN=""                # optional — raises GitHub Advisories rate limit
PATENTSVIEW_API_KEY=""         # required for the patent-registry adapter; get one at https://patentsview.org/apis/keyrequest — adapter is silently skipped if unset
SCRAPER_INTERVAL_HOURS="6"     # cron cadence for the full sweep (src/workers/arbitrage-scan.worker.ts::scheduleArbitrageSweep)

# --- Federated Edge Runtime (V2-7) -------------------------------------------
# Held only by Content Storm ops, embedded in internal node-provisioning
# tooling — never exposed to customers. Authenticates POST /api/federated/nodes,
# which registers a new VPC/local-cluster deployment. Each individual node
# then gets its OWN separate per-node bearer token (issued at registration,
# shown once) for ongoing heartbeat calls — this shared secret is only for
# the provisioning step itself, not for node-to-cloud traffic afterward.
FEDERATED_NODE_SECRET=""
HEYGEN_API_KEY=""
RUNWAY_API_KEY=""
